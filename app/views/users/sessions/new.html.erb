<% content_for(:title) { t(".sign_in") } %>

<div class="flex flex-col items-center justify-center p-6 b-full">
  <div class="flex flex-col gap i-full max-i-sm">
    <!-- Logo/Brand -->
    <div class="flex items-center justify-center gap mbe-6">
      <div class="flex items-center justify-center bg-primary rounded-md p-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="colorize-white text-sm">
          <path d="M7 2h10"></path>
          <path d="M5 6h14"></path>
          <rect width="18" height="12" x="3" y="10" rx="2"></rect>
        </svg>
      </div>
      <span class="font-semibold">Acme Inc.</span>
    </div>

    <!-- Card -->
    <div class="card">
      <!-- Card Header -->
      <div class="flex flex-col text-center p-6 pb-0">
        <h1 class="font-semibold text-xl mbe-1">
          <%= t(".sign_in_to_your_account") %>
        </h1>
        <p class="text-sm text-subtle mbe-4">
          <%= t(".use_oauth_or_email") || "Login with your account or email" %>
        </p>
      </div>

      <!-- Card Body -->
      <div class="p-6">
        <%= form_with url: users_session_path do |form| %>
          <div class="flex flex-col gap">
            <!-- OAuth Providers -->
            <div class="flex flex-col gap mbe-4">
              <%= render partial: "oauth_providers" %>
            </div>

            <!-- Divider -->
            <div class="flex items-center mbe-4">
              <div class="border-be flex-1"></div>
              <span class="text-sm text-subtle pis-3 pie-3">
                <%= t(".or_continue_with") %>
              </span>
              <div class="border-be flex-1"></div>
            </div>

            <!-- Email field -->
            <div class="mbe-4">
              <%= form.label :email_address, class: "text-sm font-medium" %>
              <%= form.email_field :email_address,
                    required: true,
                    autofocus: true,
                    autocomplete: "email",
                    placeholder: t(".email_address_placeholder"),
                    value: params[:email_address],
                    class: "input" %>
            </div>

            <!-- Password field -->
            <div class="mbe-6">
              <div class="flex items-center justify-between mbe-1">
                <%= form.label :password, class: "text-sm font-medium" %>
                <div class="text-sm">
                  <%= link_to t(".forgot_your_password"), new_users_password_reset_path, class: "underline text-sm hover:text-primary" %>
                </div>
              </div>
              <%= form.password_field :password,
                    required: true,
                    autocomplete: "current-password",
                    placeholder: t(".password_placeholder"),
                    maxlength: 72,
                    class: "input" %>
            </div>

            <!-- Login button -->
            <div class="mbe-6">
              <%= form.submit t(".sign_in"), class: "btn btn--primary i-full" %>
            </div>

            <!-- Sign up link -->
            <div class="text-center text-sm">
              <%= t(".need_an_account") %>
              <%= link_to t(".sign_up"), sign_up_path, class: "underline hover:text-primary" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Terms text -->
    <p class="text-xs text-center text-subtle mt-6">
      <%= t(".terms_agreement_html", terms_link: link_to(t(".terms_of_service"), "#", class: "underline"), privacy_link: link_to(t(".privacy_policy"), "#", class: "underline")) || "By clicking continue, you agree to our <a href='#' class='underline'>Terms of Service</a> and <a href='#' class='underline'>Privacy Policy</a>." %>
    </p>
  </div>
</div>
