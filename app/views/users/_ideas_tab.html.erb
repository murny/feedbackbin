<% if ideas.any? %>
  <ul class="flex flex-column gap-6">
    <% ideas.each do |idea| %>
      <%= render partial: "ideas/idea", locals: { idea: idea } %>
    <% end %>
  </ul>
<% else %>
  <%= render Elements::EmptyStateComponent.new(
    icon: "lightbulb",
    title: t(".empty_ideas"),
    variant: :compact
  ) %>
<% end %>
