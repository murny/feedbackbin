<%# locals: (result:) %>

<%= link_to idea_path(result.idea),
    class: "flex items-start gap-3 rounded-md px-3 py-2 text-sm transition-colors hover:bg-accent hover:text-accent-foreground",
    data: { turbo: false } do %>
  <div class="mt-0.5 shrink-0">
    <% if result.idea? %>
      <%= lucide_icon "lightbulb", class: "h-4 w-4 text-muted-foreground" %>
    <% else %>
      <%= lucide_icon "message-circle", class: "h-4 w-4 text-muted-foreground" %>
    <% end %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2">
      <span class="font-medium truncate"><%= raw result.display_title %></span>
      <%= render Elements::BadgeComponent.new(variant: :secondary, class: "shrink-0 text-xs") do %>
        <%= result.board.name %>
      <% end %>
    </div>
    <% if result.display_snippet.present? %>
      <p class="mt-0.5 text-xs text-muted-foreground line-clamp-1"><%= raw result.display_snippet %></p>
    <% end %>
    <% if result.comment? %>
      <span class="mt-0.5 inline-flex items-center text-xs text-muted-foreground">
        <%= lucide_icon "corner-down-right", class: "mr-1 h-3 w-3" %>
        <%= t("searches.result.comment_on_idea") %>
      </span>
    <% end %>
  </div>
<% end %>
