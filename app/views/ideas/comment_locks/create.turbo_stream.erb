<%= turbo_stream.replace "idea-comment-lock-button", method: :morph do %>
  <%= render Elements::DropdownMenuComponent::ItemComponent.new(
    id: "idea-comment-lock-button",
    href: idea_comment_lock_path(@idea),
    method: :delete
  ) do %>
    <%= t("ideas.show.unlock_discussion") %>
  <% end %>
<% end %>

<%= turbo_stream.replace "idea-comments-locked-badge", partial: "ideas/comments_locked_badge", method: :morph, locals: { idea: @idea } %>

<%= turbo_stream.replace "idea_comment_form", partial: "comments/form", method: :morph, locals: { comment: Comment.new, idea: @idea } %>
