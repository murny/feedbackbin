<%= turbo_stream.replace "idea-pin-button", method: :morph do %>
  <%= render Elements::DropdownMenuComponent::ItemComponent.new(
    id: "idea-pin-button",
    href: idea_pin_path(@idea),
    method: :delete
  ) do %>
    <%= t("ideas.show.unpin") %>
  <% end %>
<% end %>

<%= turbo_stream.replace "idea-pinned-badge", partial: "ideas/pinned_badge", method: :morph, locals: { idea: @idea } %>
