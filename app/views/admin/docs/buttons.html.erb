<% content_for :title, "Buttons" %>

<%= render "component_header",
  title: "Button",
  description: "Displays a button or a component that looks like a button." %>

<%# Primary button (default) %>
<%= render_button "Submit" %>

<%# Secondary button %>
<%= render_button "Cancel", variant: :secondary %>

<%# Danger button %>
<%= render_button "Delete", variant: :danger %>

<%# Outline button %>
<%= render_button "Edit", variant: :outline %>

<%# Link styled as button %>
<%= render_button "View details", as: :link, href: "#" %>

<%# With block %>
<%= render_button do %>
  <i class="icon"></i> With Icon
<% end %>
