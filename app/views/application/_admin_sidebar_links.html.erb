<div class="flex flex-col space-y-1">
  <!-- Dashboard Link -->
  <span class="relative">
    <%= active_link_to admin_root_path,
          class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium",
          active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
          inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
      <%= inline_svg "icons/home-admin.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white" %>
      <span class="truncate">Dashboard</span>
    <% end %>
  </span>

  <!-- Resources Section -->
  <div class="mt-3">
    <h3 class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-zinc-900 dark:text-white">
      <%= inline_svg "icons/users.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400" %>
      <span class="truncate">Resources</span>
    </h3>
    <div class="mt-1 pl-9 flex flex-col space-y-1">
      <%= active_link_to admin_users_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Users</span>
      <% end %>
      <%= active_link_to admin_posts_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Posts</span>
      <% end %>
      <%= active_link_to admin_organizations_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Organizations</span>
      <% end %>
    </div>
  </div>

  <!-- Docs Section -->
  <div class="mt-3">
    <h3 class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-zinc-900 dark:text-white">
      <%= inline_svg "icons/file-text.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400" %>
      <span class="truncate">Docs</span>
    </h3>
    <div class="mt-1 pl-9 flex flex-col space-y-1">
      <%= active_link_to introduction_admin_docs_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Introduction</span>
      <% end %>
      <%= active_link_to installation_admin_docs_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Installation</span>
      <% end %>
      <%= active_link_to configuration_admin_docs_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Configuration</span>
      <% end %>
      <%= active_link_to deploying_admin_docs_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Deploying</span>
      <% end %>
    </div>
  </div>

  <!-- Components Section -->
  <div class="mt-3">
    <h3 class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-zinc-900 dark:text-white">
      <%= inline_svg "icons/component.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400" %>
      <span class="truncate">Components</span>
    </h3>
    <div class="mt-1 pl-9 flex flex-col space-y-1">
      <%= active_link_to breadcrumb_admin_docs_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Breadcrumb</span>
      <% end %>
      <%= active_link_to button_admin_docs_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Button</span>
      <% end %>
      <%= active_link_to toast_admin_docs_path,
            class: "flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium",
            active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
            inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
        <span class="truncate">Toast</span>
      <% end %>
    </div>
  </div>

  <!-- Theme Toggle -->
  <div class="mt-6 px-3">
    <button class="flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring h-9 w-9 text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200"
            type="button"
            data-controller="theme"
            data-action="theme#toggle">
      <%= inline_svg "icons/sun.svg", class: "h-5 w-5 rotate-0 scale-100 transition-all dark:-rotate-90 dark:scale-0" %>
      <%= inline_svg "icons/moon.svg", class: "absolute h-5 w-5 rotate-90 scale-0 transition-all dark:rotate-0 dark:scale-100" %>
      <span class="sr-only">Toggle theme</span>
    </button>
  </div>
</div>
