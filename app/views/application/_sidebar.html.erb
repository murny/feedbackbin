<div class="fixed inset-y-0 left-0 w-64 max-lg:hidden bg-white dark:bg-zinc-900 border-r border-zinc-200 dark:border-zinc-800 shadow-sm">
  <nav class="flex h-full min-h-0 flex-col">
    <!-- Organization Selector -->
    <div class="flex flex-col border-b border-zinc-200 dark:border-zinc-800 p-4">
      <span class="relative" data-controller="dropdown">
        <button type="button"
                aria-haspopup="menu"
                aria-expanded="false"
                data-action="click->dropdown#toggle click@window->dropdown#hide"
                class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm font-medium text-zinc-800 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">
          <% if Current.user %>
            <span data-slot="avatar" class="inline-grid shrink-0 align-middle rounded-md overflow-hidden h-7 w-7">
              <%= organization_logo_tag(Current.organization) %>
            </span>
            <span class="truncate font-semibold"><%= Current.organization.name %></span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="h-4 w-4 ml-auto text-zinc-500">
              <path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"></path>
            </svg>
          <% else %>
            <span class="truncate font-semibold">FeedbackBin</span>
          <% end %>
        </button>

        <% if Current.user %>
          <!-- Organization Dropdown Menu -->
          <div class="hidden absolute left-0 top-12 z-10 w-64 origin-top-left rounded-lg bg-white dark:bg-zinc-900 shadow-lg ring-1 ring-black/5 dark:ring-white/10 focus:outline-none overflow-hidden"
               role="menu"
               aria-orientation="vertical"
               tabindex="-1"
               data-dropdown-target="menu"
               data-transition-enter="transition ease-out duration-200"
               data-transition-enter-from="opacity-0 scale-95"
               data-transition-enter-to="opacity-100 scale-100"
               data-transition-leave="transition ease-in duration-75"
               data-transition-leave-from="opacity-100 scale-100"
               data-transition-leave-to="opacity-0 scale-95">

            <!-- Settings Link - Only display if user is an organization admin -->
            <% if Current.organization_admin? %>
              <div class="py-1" role="none">
                <%= link_to "#organization_settings_path",
                      class: "group flex w-full items-center gap-3 px-4 py-2 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800",
                      role: "menuitem" do %>
                  <%= inline_svg "icons/settings.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400" %>
                  <span>Settings</span>
                <% end %>
              </div>

              <!-- Divider -->
              <div class="border-t border-zinc-200 dark:border-zinc-700 my-1"></div>
            <% end %>

            <!-- Organizations List -->
            <div class="py-1" role="none">
              <!-- Current Organization -->
              <%= link_to "#",
                    class: "flex w-full items-center gap-3 px-4 py-2 text-sm text-zinc-700 bg-zinc-50 dark:text-zinc-300 dark:bg-zinc-800/50",
                    role: "menuitem" do %>
                <span data-slot="avatar" class="inline-grid shrink-0 align-middle rounded-md overflow-hidden h-6 w-6">
                  <%= organization_logo_tag(Current.organization, initial_classes: "text-xs font-medium uppercase") %>
                </span>
                <span class="truncate font-medium"><%= Current.organization.name %></span>
              <% end %>

              <!-- Other organizations the user belongs to -->
              <% if Current.other_organizations.present? %>
                <% Current.other_organizations.each do |org| %>
                  <%= link_to "#org_path",
                        class: "flex w-full items-center gap-3 px-4 py-2 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800",
                        role: "menuitem" do %>
                    <span data-slot="avatar" class="inline-grid shrink-0 align-middle <%= org.logo.present? ? 'rounded-md' : 'rounded-full' %> overflow-hidden h-6 w-6">
                      <%= organization_logo_tag(org, initial_classes: "text-xs font-medium uppercase") %>
                    </span>
                    <span class="truncate"><%= org.name %></span>
                  <% end %>
                <% end %>
              <% end %>
            </div>

            <!-- Divider -->
            <div class="border-t border-zinc-200 dark:border-zinc-700 my-1"></div>

            <!-- New Team Link -->
            <div class="py-1" role="none">
              <%= link_to "#new_organization_path",
                    class: "flex w-full items-center gap-3 px-4 py-2 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800",
                    role: "menuitem" do %>
                <%= inline_svg "icons/plus.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400" %>
                <span>New team…</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </span>
    </div>

    <!-- Main Navigation -->
    <div class="flex flex-1 flex-col overflow-y-auto pt-2 pb-4">
      <div class="px-3 mb-6">
        <div class="flex flex-col space-y-1">
          <span class="relative">
            <%= active_link_to root_path,
                class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium",
                active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
                inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
              <%= inline_svg "icons/home.svg", class: "h-5 w-5 text-primary" %>
              <span class="truncate">Home</span>
            <% end %>
          </span>
          <span class="relative">
            <%= active_link_to "#roadmap_path",
                class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium",
                active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
                inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
              <%= inline_svg "icons/layers.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white" %>
              <span class="truncate">Roadmap</span>
            <% end %>
          </span>
          <span class="relative">
            <%= active_link_to posts_path,
                class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium",
                active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
                inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
              <%= inline_svg "icons/message-square.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white" %>
              <span class="truncate">Feedback</span>
            <% end %>
          </span>
          <span class="relative">
            <%= active_link_to changelogs_path,
                class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium",
                active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
                inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
              <%= inline_svg "icons/sparkles.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white" %>
              <span class="truncate">What's New?</span>
            <% end %>
          </span>
        </div>
      </div>

      <!-- Admin Links Section -->
      <div class="px-3 mb-6">
        <h3 class="px-3 text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
          Admin
        </h3>
        <div class="mt-2 flex flex-col space-y-1">
          <%= render "admin_sidebar_links" %>
        </div>
      </div>

      <div class="flex-1"></div>

      <!-- Support Links -->
      <div class="px-3">
        <h3 class="px-3 text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
          Help & Resources
        </h3>
        <div class="mt-2 flex flex-col space-y-1">
          <span class="relative">
            <%= active_link_to "#",
                class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium",
                active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
                inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
              <%= inline_svg "icons/help-circle.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white" %>
              <span class="truncate">Support</span>
            <% end %>
          </span>
          <span class="relative">
            <%= active_link_to "#",
                class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium",
                active_class: "text-zinc-900 dark:text-white bg-zinc-100 dark:bg-zinc-800",
                inactive_class: "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" do %>
              <%= inline_svg "icons/sparkles.svg", class: "h-5 w-5 text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white" %>
              <span class="truncate">Changelog</span>
            <% end %>
          </span>
        </div>
      </div>
    </div>

    <!-- User Profile Section -->
    <div class="border-t border-zinc-200 dark:border-zinc-800 p-4">
      <span class="relative" data-controller="dropdown">
        <button type="button"
                aria-haspopup="true"
                aria-expanded="false"
                data-action="click->dropdown#toggle click@window->dropdown#hide"
                class="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-left text-sm font-medium text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">
          <span class="flex min-w-0 items-center gap-3">
            <span class="h-9 w-9 rounded-full overflow-hidden flex-shrink-0 bg-zinc-200 dark:bg-zinc-700">
              <%= image_tag fresh_user_avatar_path(Current.user), role: "presentation", class: "h-full w-full object-cover", alt: Current.user.name %>
            </span>
            <span class="min-w-0">
              <span class="block truncate text-sm font-medium text-zinc-900 dark:text-white"><%= Current.user.name %></span>
              <span class="block truncate text-xs text-zinc-500 dark:text-zinc-400"><%= Current.user.username %></span>
            </span>
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4 ml-auto text-zinc-500">
            <path fill-rule="evenodd" d="M11.78 9.78a.75.75 0 0 1-1.06 0L8 7.06 5.28 9.78a.75.75 0 0 1-1.06-1.06l3.25-3.25a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06Z" clip-rule="evenodd"></path>
          </svg>
        </button>

        <!-- User Dropdown Menu -->
        <div class="hidden absolute right-0 bottom-12 z-10 w-56 origin-bottom-right rounded-lg bg-white dark:bg-zinc-900 shadow-lg ring-1 ring-black/5 dark:ring-white/10 focus:outline-none overflow-hidden"
             role="menu"
             aria-orientation="vertical"
             tabindex="-1"
             data-dropdown-target="menu"
             data-transition-enter="transition ease-out duration-200"
             data-transition-enter-from="opacity-0 scale-95"
             data-transition-enter-to="opacity-100 scale-100"
             data-transition-leave="transition ease-in duration-75"
             data-transition-leave-from="opacity-100 scale-100"
             data-transition-leave-to="opacity-0 scale-95">
          <!-- User Info -->
          <div class="px-4 py-3 border-b border-zinc-200 dark:border-zinc-700" role="none">
            <p class="text-sm text-zinc-500 dark:text-zinc-400" role="none">Signed in as</p>
            <p class="truncate text-sm font-medium text-zinc-900 dark:text-white" role="none"><%= Current.user.username %></p>
          </div>

          <!-- User Links -->
          <div class="py-1" role="none">
            <%= link_to t(".links.your_profile"),
                  user_path(Current.user),
                  class: "block px-4 py-2 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800",
                  role: "menuitem" %>
            <%= link_to t(".links.settings"),
                  user_settings_profile_path,
                  class: "block px-4 py-2 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800",
                  role: "menuitem" %>
          </div>

          <!-- Development Tools -->
          <% if Rails.env.development? %>
            <div class="py-1 border-t border-zinc-200 dark:border-zinc-700" role="none">
              <h3 class="px-4 py-1 text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
                Development
              </h3>
              <%= link_to t(".links.letter_opener"),
                    letter_opener_web_path,
                    class: "block px-4 py-2 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800",
                    role: "menuitem" %>
              <%= link_to t(".links.mission_control_jobs"),
                    mission_control_jobs_path,
                    class: "block px-4 py-2 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800",
                    role: "menuitem" %>
            </div>
          <% end %>

          <!-- Sign Out Button -->
          <div class="py-1 border-t border-zinc-200 dark:border-zinc-700" role="none">
            <%= button_to t(".sign_out"),
                  users_session_path,
                  method: :delete,
                  class: "w-full text-left block px-4 py-2 text-sm text-rose-600 hover:bg-zinc-100 dark:hover:bg-zinc-800" %>
          </div>

          <!-- Admin Links -->
          <% if Current.user.site_admin? %>
            <div class="py-1 border-t border-zinc-200 dark:border-zinc-700" role="none">
              <h3 class="px-4 py-1 text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
                Administration
              </h3>
              <%= link_to t(".links.admin"),
                    admin_root_path,
                    class: "block px-4 py-2 text-sm font-medium text-primary hover:bg-zinc-100 dark:hover:bg-zinc-800",
                    role: "menuitem" %>
            </div>
          <% end %>
        </div>
      </span>
    </div>
  </nav>
</div>
