<%# locals: (comment:) %>

<%= turbo_frame_tag dom_id(comment) do %>
  <div class="<%= comment.parent_id ? 'ml-4 sm:ml-8 mt-2' : 'mt-4' %>">
    <div class="rounded-lg border bg-card text-card-foreground shadow-2xs hover:shadow-md transition-shadow" data-v0-t="card">
      <div class="flex flex-col space-y-1.5 p-6 pb-3">
        <div class="flex items-start gap-3">
          <div class="flex flex-col items-center gap-1">
            <%= render partial: "likes/like_button", locals: { likeable: comment } %>
            <span class="text-xs font-medium"><%= comment.likes_count || 0 %></span>
          </div>
          <div class="flex-1">
            <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
              <div class="flex items-center gap-2">
                <span class="relative flex shrink-0 overflow-hidden rounded-full size-6">
                  <%= avatar_tag comment.creator, class: "aspect-square h-full w-full", alt: comment.creator.name %>
                </span>
                <span class="font-medium text-sm"><%= comment.creator.name %></span>
                <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 font-semibold transition-colors focus:outline-hidden focus:ring-2 focus:ring-ring focus:ring-offset-2 text-foreground text-xs" data-v0-t="badge">
                  <%= 'Member' %>
                </div>
              </div>
              <span class="text-xs text-muted-foreground sm:ml-auto"><%= l(comment.created_at, format: :long) %></span>
            </div>
            <div class="prose prose-sm max-w-none dark:prose-invert">
              <p class="text-sm leading-relaxed mb-0"><%= comment.body %></p>
            </div>
            <div class="flex items-center gap-2 mt-3">
              <button class="ring-offset-background focus-visible:outline-hidden focus-visible:ring-ring inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground rounded-md px-3 h-7 text-xs">
                <%= inline_svg_tag 'icons/heart.svg', class: 'h-3 w-3 mr-1' %>Like
              </button>
              <button class="ring-offset-background focus-visible:outline-hidden focus-visible:ring-ring inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground rounded-md h-7 w-7 p-0" type="button" aria-haspopup="menu" aria-expanded="false" data-state="closed">
                <%= inline_svg_tag 'icons/ellipsis.svg', class: 'h-3 w-3' %>
                <span class="sr-only">Comment settings</span>
              </button>
            </div>
          </div>
        </div>
        <div id="<%= dom_id(comment) %>_replies">
          <%= render partial: "comments/reply", collection: comment.replies.ordered, as: :comment %>
        </div>
        <%= render partial: "comments/reply_form", locals: { parent: comment, comment: Comment.new, show_form: false } %>
      </div>
    </div>
  </div>
<% end %>
