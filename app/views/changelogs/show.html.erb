<%= content_for :title, @changelog.title %>

<section class="center pad-inline" style="margin-block-start: var(--space-6);">
  <div class="container">
    <div class="page-header flex align-center justify-space-between">
      <%= link_to changelogs_path, class: "flex-inline align-center gap-half txt-small txt-subtle" do %>
        <%= lucide_icon "chevron-left", style: "inline-size: 1rem; block-size: 1rem;" %>
        <span><%= t(".back") %></span>
      <% end %>
      <% if authenticated? && Current.admin? %>
        <%= link_to t(".edit"), edit_admin_changelog_path(@changelog), class: "btn btn--secondary btn--sm" %>
      <% end %>
    </div>

    <article class="flex flex-column gap-6">
      <header class="flex flex-column gap-4">
        <div class="flex align-center gap-3">
          <span class="flex-inline align-center gap-1 txt-medium font-weight-semibold">
            <%= lucide_icon "calendar", class: "size-4" %>
            <span class="visually-hidden"><%= t(".published_on_label") %></span>
            <time>
              <%= local_datetime_tag @changelog.published_at, style: :datetime %>
            </time>
          </span>
          <%= render Elements::BadgeComponent.new(
            variant: changelog_badge_variant(@changelog.kind)
          ) do %>
            <%= @changelog.kind.humanize.titleize %>
          <% end %>
        </div>

        <h1 class="font-weight-bold" style="font-size: var(--text-4xl); line-height: 1.1;">
          <%= @changelog.title %>
        </h1>
      </header>

      <div class="prose prose-lg" style="max-inline-size: none; line-height: 1.625;" data-controller="syntax-highlight">
        <%= @changelog.description %>
      </div>

      <% linked_ideas = @changelog.ideas.to_a %>
      <% if linked_ideas.any? %>
        <section class="changelog-linked-ideas flex flex-column gap-3">
          <header class="flex flex-column gap-1">
            <h2 class="txt-medium font-weight-semibold"><%= t(".linked_ideas_heading") %></h2>
            <p class="txt-small txt-subtle">
              <%= t(".linked_ideas_intro", count: linked_ideas.size) %>
            </p>
          </header>

          <ul class="changelog-linked-ideas__list flex flex-column gap-2 list-unstyled">
            <% linked_ideas.each do |idea| %>
              <li>
                <%= link_to idea, class: "changelog-linked-ideas__item flex align-center gap-2", data: { turbo_frame: "_top" } do %>
                  <%= lucide_icon "lightbulb", class: "size-4 txt-subtle flex-item-no-shrink" %>
                  <span class="font-weight-medium"><%= idea.title %></span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    </article>
  </div>
</section>
