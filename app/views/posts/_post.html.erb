<%# locals: (post:) %>

<div id="<%= dom_id post %>" class="rounded-lg text-card-foreground shadow-2xs group hover:shadow-xl transition-all duration-300 hover:bg-accent/30 border hover:border-primary/20 relative overflow-hidden bg-accent/10" data-v0-t="card">
  <div class="absolute top-2 right-2 flex gap-1 z-10">
    <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
    <div class="w-2 h-2 bg-green-500 rounded-full"></div>
  </div>
  <div class="p-4 sm:p-6">
    <div class="flex gap-3 sm:gap-4 items-start">
      <!-- Upvote button and count (top-aligned left column, hidden on mobile) -->
      <div class="hidden sm:flex flex-col items-center gap-2 min-w-[60px] pt-1">
        <%= render partial: "likes/like_button", locals: { likeable: post } %>
        <span class="text-lg font-bold text-center min-w-[2ch] text-foreground"><%= post.likes_count || 0 %></span>
      </div>
      <div class="flex-1 flex flex-col gap-2 min-w-0">
        <div class="space-y-3">
          <div class="space-y-2">
            <div class="flex items-start justify-between gap-4 min-w-0">
              <h2 class="text-lg sm:text-xl font-semibold leading-tight hover:text-primary cursor-pointer transition-colors line-clamp-2 group-hover:text-primary/90 min-w-0 truncate">
                <% if post.respond_to?(:pinned?) && post.pinned? %>
                  <%= inline_svg_tag "icons/pin.svg", class: "inline size-4 text-blue-500 mr-2 align-text-bottom" %>
                <% end %>
                <%= link_to post.title, post %>
              </h2>
              <!-- Category badge (right, always visible, placeholder if missing, never overflows) -->
              <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 transition-colors focus:outline-hidden focus:ring-2 focus:ring-ring focus:ring-offset-2 flex-shrink-0 text-xs bg-primary/10 border-primary/20 text-primary font-medium whitespace-nowrap ml-2 max-w-[40vw] truncate" data-v0-t="badge">
                <%= post.category&.name.presence || 'General' %>
              </div>
            </div>
            <!-- Tags as badges (horizontal, compact, always show at least one placeholder) -->
            <div class="flex items-center gap-2 flex-wrap mt-1">
              <% if post.respond_to?(:tags) && post.tags.any? %>
                <% post.tags.each do |tag| %>
                  <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 font-semibold focus:outline-hidden focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-secondary text-secondary-foreground text-xs hover:bg-secondary/80 transition-colors cursor-pointer" data-v0-t="badge">
                    <%= inline_svg_tag "icons/hash.svg", class: "size-3 mr-1" %><%= tag.name %>
                  </span>
                <% end %>
              <% else %>
                <% 3.times do %>
                  <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 font-semibold bg-muted text-muted-foreground text-xs animate-pulse" data-v0-t="badge">
                    <%= inline_svg_tag "icons/hash.svg", class: "size-3 mr-1" %>tag
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>
          <!-- Post excerpt/description -->
          <div class="text-muted-foreground leading-relaxed cursor-pointer text-sm sm:text-base hover:text-foreground/80 transition-colors mt-1">
            <p class="line-clamp-3 sm:line-clamp-4 font-light">
              <%= truncate(strip_tags(post.body.to_s), length: 180) %>
            </p>
          </div>
        </div>
        <!-- Post meta row: author, role, date, replies, views -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mt-3 flex-wrap overflow-x-auto">
          <div class="flex gap-3 min-w-0 flex-wrap items-start">
            <span class="relative flex shrink-0 overflow-hidden rounded-full size-8 sm:size-9 ring-2 ring-background shadow-sm">
              <% if post.author.respond_to?(:avatar_url) && post.author.avatar_url.present? %>
                <img class="aspect-square h-full w-full" alt="<%= post.author.name %>" src="<%= post.author.avatar_url %>">
              <% else %>
                <span class="flex h-full w-full items-center justify-center rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white text-xs sm:text-sm font-semibold"><%= post.author.name.to_s.first(2).upcase %></span>
              <% end %>
            </span>
            <div class="flex flex-col space-y-1 min-w-0">
              <div class="flex items-center gap-2 min-w-0">
                <span class="font-medium text-sm text-foreground truncate"><%= post.author.name %></span>
                <% if post.author.respond_to?(:role) && post.author.role.present? %>
                  <span class="items-center rounded-full border px-2.5 py-0.5 font-semibold transition-colors focus:outline-hidden focus:ring-2 focus:ring-ring focus:ring-offset-2 text-foreground text-xs hidden sm:inline-flex truncate" data-v0-t="badge">
                    <%= post.author.role %>
                  </span>
                <% end %>
              </div>
              <div class="flex items-center gap-1 text-xs text-muted-foreground min-w-0">
                <%= inline_svg_tag "icons/clock.svg", class: "size-3" %>
                <span><%= l(post.created_at, format: :short) %></span>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-4 text-sm text-muted-foreground flex-shrink-0">
            <span class="flex items-center gap-1">
              <%= inline_svg_tag "icons/message-circle.svg", class: "size-4" %>
              <span class="font-medium"><%= post.comments_count.nil? ? '0' : post.comments_count %></span>
              <span class="hidden sm:inline text-xs">replies</span>
            </span>
            <span class="flex items-center gap-1">
              <%= inline_svg_tag "icons/eye.svg", class: "size-4" %>
              <span class="hidden sm:inline font-medium"><%= post.respond_to?(:views_count) && post.views_count.present? ? number_with_delimiter(post.views_count) : '0' %></span>
              <span class="sm:hidden font-medium"><%= post.respond_to?(:views_count) && post.views_count.present? ? (post.views_count > 999 ? (post.views_count / 1000).to_s + 'k' : post.views_count) : '0' %></span>
              <span class="hidden sm:inline text-xs">views</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
