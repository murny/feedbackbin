<%# locals: (post:) %>

<%= form_with(model: post, class: "grid gap-6") do |form| %>
  <%= render "error_messages", resource: form.object %>

  <div class="grid gap-3">
    <%= form.label :category_id, t("category") %>
    <%= form.select :category_id,
        options_from_collection_for_select(@categories, :id, :name, post.category_id),
        { prompt: t("select_category") },
        { class: "select" } %>
  </div>

  <div class="grid gap-3">
    <%= form.label :title %>
    <%= form.text_field :title, autofocus: true, placeholder: t(".title_placeholder") %>
  </div>

  <div class="grid gap-3" data-controller="local-save" data-local-save-key-value="<%= post.new_record? ? 'post_new_body' : "post_#{post.id}_body" %>">
    <%= form.label :body %>
    <%= form.rich_textarea :body, placeholder: t(".body_placeholder"), data: { local_save_target: "input", action: "lexxy:change->local-save#save turbo:submit-end->local-save#submit" } do %>
      <%= mentions_prompt %>
    <% end %>
  </div>

  <div class="flex justify-end gap-3 pt-2">
    <% if form.object.new_record? %>
      <%= link_to t("cancel"), posts_path, class: "btn btn-secondary" %>
    <% else %>
      <%= link_to t("cancel"), post_path(@post), class: "btn btn-secondary" %>
    <% end %>

    <%= form.submit class: "btn" %>
  </div>
<% end %>
