<%= content_for :title, t("posts.index.title") %>
<%= turbo_stream_from :posts %>

<section class="max-w-6xl mx-auto px-4 sm:px-6">
  <div class="md:pr-6 lg:pr-10">
    <!-- Header Section -->
    <div class="border-b border-border p-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-foreground tracking-tight">Forum Discussions</h1>
          <p class="text-muted-foreground mt-1">6 active discussions in the community</p>
        </div>
        <%= render_button(text: "New Thread", variant: :default, href: "#", class: "shrink-0") do %>
          <%= inline_svg_tag "icons/plus.svg", class: "mr-2" %>
          New Thread
        <% end %>
      </div>

      <!-- Categories and Filters -->
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
        <!-- Category Tabs -->
        <div class="flex flex-wrap gap-2">
          <%= link_to "All Categories", "#",
                class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-md transition-colors bg-primary text-primary-foreground" %>
          <%= link_to "General", "#", 
                class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-md transition-colors hover:bg-muted text-muted-foreground" %>
          <%= link_to "Development", "#",
                class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-md transition-colors hover:bg-muted text-muted-foreground" %>
          <%= link_to "Community", "#",
                class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-md transition-colors hover:bg-muted text-muted-foreground" %>
        </div>

        <!-- Sort Options -->
        <div class="flex items-center gap-2">
          <span class="text-sm text-muted-foreground mr-2">Sort by:</span>
          <%= link_to "Latest", "#", 
                class: "px-3 py-1 text-sm font-medium rounded-md hover:bg-muted transition-colors bg-primary text-primary-foreground" %>
          <%= link_to "Popular", "#", 
                class: "px-3 py-1 text-sm font-medium rounded-md hover:bg-muted transition-colors text-muted-foreground" %>
          <%= link_to "Top", "#", 
                class: "px-3 py-1 text-sm font-medium rounded-md hover:bg-muted transition-colors text-muted-foreground" %>
        </div>
      </div>
    </div>

    <%= tag.div id: ("posts" if first_page?(@pagy.page)), class: "mb-12" do %>
      <% if @posts.empty? %>
        <div class="text-center my-3">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">No feedback yet</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by creating a new suggestion.</p>
          <div class="mt-6">
            <%= link_to new_post_path, class: "inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" do %>
              <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
              </svg>
            <%= t("posts.new.title") %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="space-y-4 mb-8">
          <%= render partial: "posts/modern_post_card", collection: @posts, as: :post %>
        </div>
      <% end %>
    <% end %>

    <% if @pagy.pages > 1 %>
      <div class="flex items-center justify-between px-4 py-3 sm:px-6">
        <%== pagy_info(@pagy) %>
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</section>
