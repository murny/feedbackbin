<%#
  Partial for displaying code examples with syntax highlighting

  Parameters:
  - title: Title for the example (optional)
  - description: Description text (optional)
  - language: Language for syntax highlighting (defaults to "erb")
  - id: HTML ID for the example (optional)
  - show_preview: Whether to show the rendered result (defaults to true)

  Block:
  - The block content contains the actual code example
%>

<%
  # Set defaults
  language ||= "erb"
  show_preview = true if show_preview.nil?

  # Initialize Rouge for this example
  require 'rouge'
  formatter = Rouge::Formatters::HTML.new
  lexer = Rouge::Lexer.find(language) || Rouge::Lexer::PlainText.new

  # Get the code from the block
  code_content = capture do
    yield
  end

  # Generate ID if not provided
  id ||= "example-#{SecureRandom.hex(4)}"

  # Process code for highlighting
  highlighted_code = formatter.format(lexer.lex(code_content.strip))
%>

<div class="code-example bg-gray-50 dark:bg-gray-800 rounded-lg overflow-hidden shadow-sm border border-gray-200 dark:border-gray-700 mb-8" id="<%= id %>">
  <% if local_assigns[:title].present? %>
    <h3 class="example-title text-xl font-medium text-gray-800 dark:text-gray-100 mb-2 px-4 pt-4"><%= title %></h3>
  <% end %>

  <% if local_assigns[:description].present? %>
    <div class="example-description text-gray-800 dark:text-gray-100 text-sm px-4 pb-3"><%= description %></div>
  <% end %>

  <div class="code-snippet bg-gray-100 dark:bg-gray-900 border-t border-b border-gray-200 dark:border-gray-700">
    <div class="snippet-header flex justify-between items-center px-4 py-2 bg-gray-200 dark:bg-gray-700">
      <span class="language-label text-xs font-semibold text-gray-600 dark:text-gray-300"><%= language.upcase %></span>
      <button class="copy-button text-xs bg-gray-300 dark:bg-gray-600 hover:bg-gray-400 dark:hover:bg-gray-500 text-gray-700 dark:text-gray-200 py-1 px-3 rounded transition-colors" data-clipboard-target="#<%= id %>-code">Copy</button>
    </div>
    <pre id="<%= id %>-code" class="p-4 text-sm overflow-x-auto text-gray-800 dark:text-gray-200 font-mono"><%= raw highlighted_code %></pre>
  </div>

  <% if show_preview %>
    <div class="example-preview">
      <div class="preview-header bg-gray-200 dark:bg-gray-700 px-4 py-2 text-xs font-semibold text-gray-600 dark:text-gray-300">Result</div>
      <div class="preview-content p-4 bg-white dark:bg-gray-900 flex items-center justify-center border-t border-gray-200 dark:border-gray-700">
        <div class="text-gray-900 dark:text-white w-full">
          <%= render inline: code_content %>
        </div>
      </div>
    </div>
  <% end %>
</div>