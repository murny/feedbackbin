<%# locals: (status:, ideas:) %>

<div class="roadmap-column">
  <!-- Column Header -->
  <div class="flex align-center" style="margin-block-end: var(--space-4); gap: var(--space-2);">
    <h2 class="txt-medium font-weight-bold">
      <%= render Elements::BadgeComponent.new(color: status.color, tone: :soft, with_dot: true) do %>
        <%= status.name %>
      <% end %>
    </h2>
    <span class="txt-small txt-subtle">
      (<%= ideas.size %>)
    </span>
  </div>

  <!-- Ideas List -->
  <div class="flex flex-column gap-3">
    <% if ideas.any? %>
      <% ideas.each do |idea| %>
        <%= render "idea_card", idea: idea %>
      <% end %>
    <% else %>
      <%= render Elements::EmptyStateComponent.new(
        icon: "inbox",
        title: "",
        description: t(".no_ideas"),
        variant: :inline
      ) %>
    <% end %>
  </div>
</div>
