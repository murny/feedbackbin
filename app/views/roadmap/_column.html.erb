<%# locals: (status:, ideas:) %>

<div class="roadmap-column">
  <header class="roadmap-column__header flex align-center justify-space-between gap-2" style="margin-block-end: var(--space-3);">
    <h2 class="txt-medium font-weight-semibold">
      <%= render Elements::BadgeComponent.new(color: status.color, tone: :soft, with_dot: true) do %>
        <%= status.name %>
      <% end %>
    </h2>
    <span class="txt-small txt-subtle font-weight-medium"><%= ideas.size %></span>
  </header>

  <div class="flex flex-column gap-3">
    <% if ideas.any? %>
      <% ideas.each do |idea| %>
        <%= render "idea_card", idea: idea %>
      <% end %>
    <% else %>
      <%= render Elements::EmptyStateComponent.new(
        icon: "inbox",
        description: t(".no_ideas"),
        variant: :inline,
        class: "roadmap-column__empty"
      ) %>
    <% end %>
  </div>
</div>
